    },
    {
      "id": "build",
      "command": "pnpm evidence:command --id build --out tests/reports/aura3d104/build.json --cwd . -- pnpm build",
      "outputs": [
        "tests/reports/aura3d104/build.json",
        "tests/reports/game-runtime/build.log"

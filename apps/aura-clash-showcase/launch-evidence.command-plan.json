{
  "name": "Aura Clash and Aura3D 1.0.5 launch evidence command plan",
  "version": "1.0.0",
  "purpose": "Lists the exact command-proof outputs consumed by launch-evidence/cross-runtime-evidence.json and docs/project/aura-clash-showcase.md.",
  "runner": "pnpm evidence:command",
  "notes": [
    "This file is a source plan only. It does not prove any gate until the commands are executed.",
    "Run commands from /Users/gurbakshchahal/aura3d unless a command overrides cwd.",
    "Deploy and user visual approval still require explicit operator approval.",
    "AuraVoice sample render gates require real rendered/video/screenshot artifacts, not placeholder JSON."
  ],
  "auraClashLocal": [
    {
      "id": "aura-clash-launch-proof-local",
      "cwd": "apps/aura-clash-showcase",
      "command": "npm run launch:proof",
      "outputs": [
        "apps/aura-clash-showcase/launch-evidence/local-gates.json",
        "apps/aura-clash-showcase/launch-evidence/first-frame.json",
        "apps/aura-clash-showcase/launch-evidence/first-frame.png",
        "apps/aura-clash-showcase/launch-evidence/review-package.md",
        "apps/aura-clash-showcase/launch-evidence/workflow.json"
      ],
      "prdGates": [463]
    },
    {
      "id": "aura-clash-visual-approval",
      "cwd": "apps/aura-clash-showcase",
      "command": "AURA_CLASH_APPROVED_BY='<name>' AURA_CLASH_VISUAL_APPROVAL_CONFIRMED=1 npm run launch:approve-visual",
      "outputs": [
        "apps/aura-clash-showcase/launch-evidence/visual-approval.json"
      ],
      "requires": [
        "Explicit user approval of launch-evidence/first-frame.png and launch-evidence/review-package.md"
      ]
    }
  ],
  "auraClashDeploy": [
    {
      "id": "aura-clash-vercel-deploy",
      "cwd": "apps/aura-clash-showcase",
      "command": "npm run launch:deploy",
      "output": "apps/aura-clash-showcase/launch-evidence/vercel-deploy.json",
      "prdGates": [464],
      "requires": [
        "Explicit deploy approval and valid Vercel credentials"
      ]
    },
    {
      "id": "aura-clash-deployed-route-evidence",
      "cwd": "apps/aura-clash-showcase",
      "command": "AURA_CLASH_ORIGIN='<production-origin>' npm run launch:evidence",
      "output": "apps/aura-clash-showcase/launch-evidence/deployed-routes.json",
      "prdGates": [465, 494],
      "requires": [
        "A successful Vercel deployment",
        "AURA_CLASH_ORIGIN or AURA_CLASH_PRODUCTION_URL points at the production deployment"
      ]
    },
    {
      "id": "aura-clash-vercel-deploy-and-route-proof",
      "cwd": "apps/aura-clash-showcase",
      "command": "AURA_CLASH_RUN_VERCEL_DEPLOY=1 AURA_CLASH_RUN_DEPLOYED_EVIDENCE=1 npm run launch:proof",
      "outputs": [
        "apps/aura-clash-showcase/launch-evidence/vercel-deploy.json",
        "apps/aura-clash-showcase/launch-evidence/deployed-routes.json"
      ],
      "prdGates": [464, 465, 494],
      "requires": [
        "Explicit deploy approval and valid Vercel credentials"
      ]
    }
  ],
  "aura3d104": [

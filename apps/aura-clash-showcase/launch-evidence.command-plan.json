    {
      "id": "dist-agent-api-types",
      "command": "pnpm evidence:command --id dist-agent-api-types --out tests/reports/aura3d104/dist-agent-api-types.json --cwd . -- node tools/evidence/verify-agent-api-types.mjs",
      "output": "tests/reports/aura3d104/dist-agent-api-types.json",

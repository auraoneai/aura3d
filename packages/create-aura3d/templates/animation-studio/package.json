{
  "name": "aura3d-animation-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "studio": "cd studio && vite",
    "episode:render-3d": "tsx scripts/render-live.ts",
    "episode:generate": "tsx scripts/generate-scene.ts",
    "scene": "tsx scripts/animation-scene.ts",
    "scene:preview": "tsx scripts/preview-server.ts",
    "scene:determinism": "tsx scripts/determinism-check.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@aura3d/animation": "1.3.2",
    "@aura3d/assets": "1.3.2",
    "@aura3d/core": "1.3.2",
    "@aura3d/engine": "1.3.2",
    "@aura3d/physics": "1.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}

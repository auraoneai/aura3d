{
  "name": "create-aura3d",
  "version": "1.1.0",
  "type": "module",
  "bin": {
    "create-aura3d": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates/product-viewer",
    "templates/cinematic-scene",
    "templates/mini-game",
    "templates/fighting-game",
    "templates/cartoon-channel",
    "templates/prompt-cartoon-channel",
    "templates/cartoon-studio",
    "templates/episode-builder"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Scaffold Aura3D browser 3D apps for product viewers, cinematic scenes, mini-games, fighting-game runtimes, prompt-driven cartoon channels, cartoon studios, and episode builders.",
  "keywords": [
    "create-aura3d",
    "vite",
    "3d-template",
    "browser-3d",
    "product-viewer",
    "fighting-game",
    "prompt-cartoon-channel",
    "cartoon-studio",
    "episode-builder",
    "cartoon-animation",
    "prompt-to-video",
    "game-runtime",
    "gltf",
    "glb",
    "typescript",
    "ai-agents"
  ],
  "homepage": "https://github.com/auraoneai/aura3d#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auraoneai/aura3d.git",
    "directory": "packages/create-aura3d"
  },
  "bugs": {
    "url": "https://github.com/auraoneai/aura3d/issues"
  },
  "license": "MIT"
}

      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Scaffold Vite browser 3D apps for Aura3D with product viewer, cinematic scene, and mini-game templates.",

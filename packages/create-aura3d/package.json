    "browser-3d",
    "product-viewer",
    "gltf",
    "glb",
    "typescript",
    "ai-agents"
  ],
  "homepage": "https://github.com/gchahal1982/aura3d#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gchahal1982/aura3d.git",
    "directory": "packages/create-aura3d"
  },

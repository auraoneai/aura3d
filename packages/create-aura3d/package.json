{
  "name": "create-aura3d",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "create-aura3d": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates/product-viewer",
    "templates/cinematic-scene",
    "templates/mini-game"
  ],

{
  "name": "@aura3d/cli",
  "version": "1.3.3",
  "type": "module",
  "bin": {
    "aura3d": "dist/cli.js",
    "aura": "dist/cli.js",
    "cli": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@aura3d/asset-index": "workspace:*"
  },
  "description": "Aura3D CLI for typed GLB/glTF assets, game/animation readiness, character assembly, agent setup, diagnostics, and deploy checks.",
  "keywords": [
    "aura3d",
    "3d",
    "gltf",
    "glb",
    "typed-assets",
    "game-assets",
    "animation-animation",
    "character-assembly",
    "ai-agents",
    "vite",
    "static-deploy",
    "diagnostics"
  ],
  "homepage": "https://github.com/auraoneai/aura3d#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auraoneai/aura3d.git",
    "directory": "packages/aura3d-cli"
  },
  "bugs": {
    "url": "https://github.com/auraoneai/aura3d/issues"
  },
  "license": "MIT"
}

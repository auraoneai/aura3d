+  /**
+   * Creates velocity buffer for motion vectors.
+   * Used by MotionBlur and TAA post-processing effects.
+   *
+   * @returns WebGL texture for velocity data (RG16F format)
+   */
+  private createVelocityBuffer(): WebGLTexture | null {
+    const device = this.device as any;
+    if (!device.getGL) {
+      logger.warn('Cannot create velocity buffer: no GL context');
+      return null;
+    }
+
+    const gl = device.getGL() as WebGL2RenderingContext;
+    const texture = gl.createTexture();
+    if (!texture) {
+      logger.error('Failed to create velocity buffer texture');
+      return null;
+    }
+
+    gl.bindTexture(gl.TEXTURE_2D, texture);
+
+    // Use RG16F format for 2D velocity vectors (screen-space motion)
+    gl.texImage2D(
+      gl.TEXTURE_2D,
+      0,
+      gl.RG16F,
+      this.renderWidth,
+      this.renderHeight,
+      0,
+      gl.RG,
+      gl.FLOAT,
+      null
+    );
+
+    // Set texture parameters for velocity buffer
+    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST);
+    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST);
+    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
+    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
+
+    gl.bindTexture(gl.TEXTURE_2D, null);
+
+    logger.debug(`Velocity buffer created: ${this.renderWidth}x${this.renderHeight} (RG16F)`);
+    return texture;
+  }

# ============================================================================
# Keep These (Don't Ignore)
# ============================================================================

# Keep example configs
!*.example.json
!*.example.ts
!*.example.js

# Keep documentation
!docs/**/*.md
!README.md
!CHANGELOG.md
!LICENSE

# Keep CI configs
!.github/
!.gitlab-ci.yml
!.travis.yml
!.circleci/

# Keep package manager files
!package.json
!pnpm-lock.yaml
!tsconfig.json
!.npmrc
!.pnpmfile.cjs

      logger.warn('Render graph not compiled, using direct rendering fallback');
      this.renderSceneMeshes(scene, camera);
    }

    if (this.profiler) {
      this.profiler.endPass();
    }"""

if old in content:
    with open('src/rendering/Renderer.ts', 'w') as f:
        f.write(content.replace(old, new))

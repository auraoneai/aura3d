{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmitOnError": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "tests/unit/**/*.ts",
    "tests/integration/**/*.ts",
    "tests/performance/**/*.ts",
    "tests/visual/**/*.ts",
    "tools/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "eslint.config.js"
  ],
  "exclude": ["dist", "node_modules"]
}

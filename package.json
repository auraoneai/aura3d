{
  "name": "@galileo3d/engine",
  "version": "0.1.0-alpha.0",
  "private": false,
  "type": "module",
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/animation",
    "dist/assets",
    "dist/audio",
    "dist/core",
    "dist/debug",
    "dist/ecs",
    "dist/editor",
    "dist/editor-runtime",
    "dist/input",
    "dist/math",
    "dist/physics",
    "dist/rendering",
    "dist/scene",
    "dist/scripting",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./math": "./dist/math/index.js",
    "./scene": "./dist/scene/index.js",
    "./ecs": "./dist/ecs/index.js",
    "./rendering": "./dist/rendering/index.js",
    "./physics": "./dist/physics/index.js",
    "./animation": "./dist/animation/index.js",
    "./assets": "./dist/assets/index.js",
    "./input": "./dist/input/index.js",
    "./audio": "./dist/audio/index.js",
    "./scripting": "./dist/scripting/index.js",
    "./editor-runtime": "./dist/editor-runtime/index.js",
    "./editor": "./dist/editor/index.js",
    "./debug": "./dist/debug/index.js"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "typecheck:ws1": "tsc -p tsconfig.build.json --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit --reporter=default --reporter=json --outputFile=tests/reports/unit.json",
    "test:integration": "vitest run tests/integration --reporter=default --reporter=json --outputFile=tests/reports/integration.json",
    "test:templates": "vitest run --config tests/templates/vitest.config.ts",
    "test:ws1": "vitest run tests/unit/math tests/unit/core tests/unit/tools tests/integration/engine-loop.test.ts",
    "test:browser": "playwright test tests/browser",
    "test:visual": "node --experimental-strip-types tools/visual-baseline/index.ts",
    "build": "tsc -p tsconfig.build.json && node --experimental-strip-types tools/finalize-dist/index.ts",
    "verify:architecture": "node --experimental-strip-types tools/verify-architecture/index.ts",
    "verify:boundaries": "node --experimental-strip-types tools/verify-boundaries/index.ts",
    "verify:exports": "node --experimental-strip-types tools/verify-exports/index.ts",
    "verify:exports:ws1": "node --experimental-strip-types tools/verify-exports/index.ts --packages math,core",
    "verify:shaders": "node --experimental-strip-types tools/verify-shaders/index.ts",
    "verify:imports": "node --experimental-strip-types tools/verify-imports/index.ts",
    "verify:size": "node --experimental-strip-types tools/package-size/index.ts",
    "verify:source-cleanliness": "node --experimental-strip-types tools/verify-source-cleanliness/index.ts",
    "verify:clean-checkout": "node --experimental-strip-types tools/clean-checkout-verification/index.ts",
    "verify:performance": "tsx --tsconfig tsconfig.base.json tests/performance/system-baselines.ts",
    "verify:demos": "node --experimental-strip-types tools/final-demo-validation/index.ts",
    "verify:external-demos": "node --experimental-strip-types tools/external-demo-validation/index.ts",
    "verify:versioned-release": "node --experimental-strip-types tools/versioned-release-verification/index.ts",
    "verify:docs-consistency": "node --experimental-strip-types tools/doc-contradiction-scan/index.ts",
    "verify:api-docs": "node --experimental-strip-types tools/api-docs/index.ts",
    "verify:docs-version": "node --experimental-strip-types tools/docs-version-alignment/index.ts",
    "verify:templates": "node --experimental-strip-types tools/template-verification/index.ts",
    "verify:claims": "node --experimental-strip-types tools/claim-registry/index.ts",
    "trace:requirements": "node --experimental-strip-types tools/requirements-trace/index.ts",
    "verify:trace": "node --experimental-strip-types tools/verify-trace/index.ts",
    "verify:release": "node --experimental-strip-types tools/release-verification/index.ts",
    "verify:release:quick": "node --experimental-strip-types tools/release-verification/index.ts --quick",
    "verify:release:repeat": "node --experimental-strip-types tools/release-verification/index.ts --repeat 3",
    "verify": "pnpm verify:release"
  },
  "devDependencies": {
    "@babylonjs/core": "^7.16.1",
    "@babylonjs/loaders": "^7.16.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "babylonjs-gltf2interface": "7.16.1",
    "cannon-es": "0.20.0",
    "draco3d": "^1.5.7",
    "esbuild": "^0.28.0",
    "eslint": "^9.26.0",
    "meshoptimizer": "^1.1.1",
    "three": "^0.165.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@loaders.gl/core": "4.4.1",
    "@loaders.gl/textures": "4.4.1"
  }
}
